# ============================================================================
# GeneFoundry router — PATIENT-DATA / ON-PREM deployment profile
# ============================================================================
# Use this profile for any deployment where prompts MAY carry patient-derived
# variants or phenotypes (GDPR Art. 9 special-category health data).
#
# It differs from the public-research profile in exactly two ways:
#   1. Edge authentication is MANDATORY (no anonymous access).
#   2. AutoPVS1 is DISABLED. The public AutoPVS1 backend scrapes a third-party
#      CN service (autopvs1.bgi.com) and forwards variant coordinates to it —
#      a third-country transfer of possibly Art. 9 data (router #32,
#      autopvs1-link #41). It is intentionally NOT wired here.
#
# The router disables a backend whose *_URL is unset (server.py "missing_url"
# skip), so leaving GF_AUTOPVS1_URL out is what removes AutoPVS1 from the
# federated catalog. Verify after deploy: `genefoundry-router list-tools`
# must show no `autopvs1_` tool.
#
# NOTE: application config is not an egress firewall. A hospital deployment
# MUST ALSO enforce a network-level egress deny for autopvs1.bgi.com (and any
# other non-approved upstream). See docs/SECURITY-ASSESSMENT-2026-06-29.md.
# To self-host AutoPVS1 instead of disabling it, point GF_AUTOPVS1_URL at the
# internal instance and set its upstream base_url to the self-hosted service.
# ============================================================================

# --- Router runtime ---
GF_HOST=0.0.0.0
GF_PORT=8000
GF_MCP_PATH=/mcp
GF_LOG_LEVEL=INFO
GF_SERVERS_FILE=servers.yaml
GF_SEARCH_MAX_RESULTS=5
GF_BACKEND_TIMEOUT=120
GF_MAX_BODY_BYTES=4000000
GF_RATE_LIMIT_RPM=120          # enable inbound rate limiting for a public/hospital bind
GF_TRUSTED_PROXY_HOPS=1
GF_REWRITE_HINTS=true
GF_POLL_INTERVAL=300           # non-zero: re-list backends and re-check drift periodically
GF_DRIFT_MODE=enforce          # fail closed on tool-definition drift (rug-pull tripwire)
GF_DRIFT_BASELINE=

# --- Transport security (MCP Origin/DNS-rebinding) ---
# Non-loopback bind REQUIRES a non-empty Host allowlist; include the public hostname.
GF_ALLOWED_HOSTS=genefoundry.example.org,localhost,127.0.0.1,::1
GF_HEALTHCHECK_HOST=localhost
GF_ALLOWED_ORIGINS=
GF_PUBLIC_BASE_URL=https://genefoundry.example.org/mcp

# --- Auth (MANDATORY for patient-data deployments) ---
# GF_AUTH_MODE=none is FORBIDDEN here. Use oauth (recommended) or jwt.
GF_AUTH_MODE=oauth
GF_ALLOW_INSECURE=false
GF_JWT_ISSUER=https://idp.example.org/
GF_JWT_JWKS_URL=https://idp.example.org/.well-known/jwks.json
GF_JWT_AUDIENCE=https://genefoundry.example.org/mcp
GF_OAUTH_PROVIDER=generic
# GF_OAUTH_CLIENT_ID=
# GF_OAUTH_CLIENT_SECRET=
# GF_OAUTH_BASE_URL=
# GF_OAUTH_AUTHORIZE_URL=
# GF_OAUTH_TOKEN_URL=

# --- Backend /mcp URLs (approved read-only backends; AutoPVS1 intentionally absent) ---
GF_GNOMAD_URL=https://gnomad-link.example.org/mcp
GF_GTEX_URL=https://gtex-link.example.org/mcp
GF_HGNC_URL=https://hgnc-link.example.org/mcp
GF_MGI_URL=https://mgi-link.example.org/mcp
GF_UNIPROT_URL=https://uniprot-link.example.org/mcp
GF_CLINGEN_URL=https://clingen-link.example.org/mcp
GF_GENCC_URL=https://gencc-link.example.org/mcp
GF_LITVAR_URL=https://litvar-link.example.org/mcp
GF_STRINGDB_URL=https://stringdb-link.example.org/mcp
# GF_AUTOPVS1_URL is intentionally UNSET — AutoPVS1 is disabled for patient data
# (third-country transfer to autopvs1.bgi.com; router #32). Do not add it here.
GF_SPLICEAI_URL=https://spliceailookup-link.example.org/mcp
GF_GENEREVIEWS_URL=https://genereviews-link.example.org/mcp
GF_PUBTATOR_URL=https://pubtator-link.example.org/mcp
# Router-owned PubTator service credential (must match PUBTATOR_LINK_MCP_SERVICE_TOKEN).
# GF_PUBTATOR_TOKEN=replace-with-a-secret-store-value
GF_CLINVAR_URL=https://clinvar-link.example.org/mcp
GF_VEP_URL=https://vep-link.example.org/mcp
GF_PANELAPP_URL=https://panelapp-link.example.org/mcp
GF_MONDO_URL=https://mondo-link.example.org/mcp
GF_MAVEDB_URL=https://mavedb-link.example.org/mcp
GF_HPO_URL=https://hpo-link.example.org/mcp
GF_METADOME_URL=https://metadome-link.example.org/mcp
GF_ORPHANET_URL=https://orphanet-link.example.org/mcp
