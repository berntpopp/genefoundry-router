GF_HOST=0.0.0.0
GF_PORT=8000
GF_MCP_PATH=/mcp
GF_LOG_LEVEL=INFO
# ─────────────────────────────────────────────────────────────────────────────
# Authentication (edge auth on the router). See README → "Authentication".
#
# The router REFUSES to start with GF_AUTH_MODE=none on a non-loopback bind
# (e.g. GF_HOST=0.0.0.0) unless GF_ALLOW_INSECURE=true — so an unauthenticated,
# publicly-reachable MCP endpoint is never started by accident. Pick ONE option:
#
# (A) Deliberately-public, no login — the fleet's current posture. Honest and
#     explicit: acknowledge the open endpoint with the escape hatch. UNCOMMENT both
#     to opt in; left commented the router FAILS CLOSED (refuses to start auth=none on
#     a 0.0.0.0 bind) until you pick exactly one of (A)/(B)/(C).
# GF_AUTH_MODE=none
# GF_ALLOW_INSECURE=true
#
# (B) oauth — interactive OAuth 2.1 for browser MCP clients (claude.ai, Cursor).
#     The router is an OAuth resource server + proxy: it validates JWT access
#     tokens (JWKS below) AND fronts an upstream provider so clients can log in.
#     Example values assume a self-hosted Keycloak at auth.genefoundry.org,
#     realm "genefoundry", confidential client "genefoundry-router". On that
#     Keycloak client, whitelist the router's OAuthProxy callback as a Valid
#     Redirect URI: https://genefoundry.org/auth/callback. Keep Keycloak's
#     Dynamic Client Registration CLOSED — the router's OAuthProxy IS the DCR
#     facade (it serves /register itself; MCP clients never register upstream).
# GF_AUTH_MODE=oauth
# GF_OAUTH_PROVIDER=keycloak
# GF_OAUTH_CLIENT_ID=genefoundry-router
# GF_OAUTH_CLIENT_SECRET=            # SECRET — set in the server .env.docker, never commit
# GF_OAUTH_AUTHORIZE_URL=https://auth.genefoundry.org/realms/genefoundry/protocol/openid-connect/auth
# GF_OAUTH_TOKEN_URL=https://auth.genefoundry.org/realms/genefoundry/protocol/openid-connect/token
# GF_JWT_ISSUER=https://auth.genefoundry.org/realms/genefoundry
# GF_JWT_JWKS_URL=https://auth.genefoundry.org/realms/genefoundry/protocol/openid-connect/certs
# GF_JWT_AUDIENCE=https://genefoundry.org/mcp   # MUST equal the access tokens' `aud` claim
#     Fixed key for the router's own OAuthProxy-minted tokens + its on-disk client
#     store. SECRET — set in the server .env.docker, never commit. Generate once with
#     `python -c "import secrets;print(secrets.token_urlsafe(48))"` and DO NOT rotate
#     (rotating invalidates live sessions + orphans the persisted client store). If
#     unset, fastmcp derives it from GF_OAUTH_CLIENT_SECRET (stable but coupled to it).
#     Pairs with the persistent FASTMCP_HOME volume in docker-compose.prod.yml.
# GF_OAUTH_JWT_SIGNING_KEY=
#     Consent screen: external (skip; Keycloak is the gate) | true | remember | false.
#     Default external for a unified single-page branded login. Optional.
# GF_OAUTH_REQUIRE_CONSENT=external
#
# (C) jwt — machine-to-machine only (bearer JWTs from an external IdP; no
#     interactive-login facade). Uses the same JWKS trio as (B):
# GF_AUTH_MODE=jwt
# GF_JWT_ISSUER=https://auth.genefoundry.org/realms/genefoundry
# GF_JWT_JWKS_URL=https://auth.genefoundry.org/realms/genefoundry/protocol/openid-connect/certs
# GF_JWT_AUDIENCE=https://genefoundry.org/mcp
# ─────────────────────────────────────────────────────────────────────────────
# GF_PUBLIC_BASE_URL — the router's public ROOT origin (scheme + host, NO path).
# The OAuth endpoints (/authorize, /token, /register, /.well-known/*) are served
# at the root, so this MUST be the bare origin; the MCP endpoint is this + the
# GF_MCP_PATH (/mcp), and that full URL (https://genefoundry.org/mcp) is the
# OAuth *resource* / token audience (see GF_JWT_AUDIENCE above). Setting a path
# here (…/mcp) mis-advertises OAuth endpoints as …/mcp/authorize and doubles the
# protected-resource-metadata URL — don't. Behind nginx-proxy-manager, binding
# GF_HOST=0.0.0.0 inside the container is expected (the localhost-bind SHOULD is
# scoped to locally-reachable servers).
GF_PUBLIC_BASE_URL=https://genefoundry.org
GF_ALLOWED_HOSTS=genefoundry.org
GF_ALLOWED_ORIGINS=https://claude.ai,https://cursor.sh
# Inbound request limits / proxy attribution. GF_TRUSTED_PROXY_HOPS=1 keys the rate
# limiter on the peer nginx-proxy-manager appends to X-Forwarded-For (0 = ignore XFF).
GF_TRUSTED_PROXY_HOPS=1
# Optional Prometheus scrape token. Unset = public /metrics; set to require
# `Authorization: Bearer <token>`. /health stays public for the container healthcheck.
# GF_METRICS_TOKEN=
GENEFOUNDRY_ROUTER_HOST_PORT=8010
# Shared external network the nginx-proxy-manager container lives on (VPS: npm_default).
NPM_NETWORK_NAME=npm_default

# Backend /mcp URLs — the live VPS fleet at *.genefoundry.org.
GF_GNOMAD_URL=https://gnomad-link.genefoundry.org/mcp
GF_GTEX_URL=https://gtex-link.genefoundry.org/mcp
GF_HGNC_URL=https://hgnc-link.genefoundry.org/mcp
GF_MGI_URL=https://mgi-link.genefoundry.org/mcp
GF_UNIPROT_URL=https://uniprot-link.genefoundry.org/mcp
GF_CLINGEN_URL=https://clingen-link.genefoundry.org/mcp
GF_GENCC_URL=https://gencc-link.genefoundry.org/mcp
GF_LITVAR_URL=https://litvar-link.genefoundry.org/mcp
GF_STRINGDB_URL=https://stringdb-link.genefoundry.org/mcp
GF_AUTOPVS1_URL=https://autopvs1-link.genefoundry.org/mcp
GF_SPLICEAI_URL=https://spliceailookup-link.genefoundry.org/mcp
GF_GENEREVIEWS_URL=https://genereviews-link.genefoundry.org/mcp
GF_PUBTATOR_URL=https://pubtator-link.genefoundry.org/mcp
# Router-owned credential; stage it here before the backend begins enforcing the matching token.
# Must match PUBTATOR_LINK_MCP_SERVICE_TOKEN on the backend.
# GF_PUBTATOR_TOKEN=replace-with-a-secret-store-value
# Staged/new backends:
GF_CLINVAR_URL=https://clinvar-link.genefoundry.org/mcp
GF_VEP_URL=https://vep-link.genefoundry.org/mcp
GF_PANELAPP_URL=https://panelapp-link.genefoundry.org/mcp
GF_MONDO_URL=https://mondo-link.genefoundry.org/mcp
GF_MAVEDB_URL=https://mavedb-link.genefoundry.org/mcp
GF_HPO_URL=https://hpo-link.genefoundry.org/mcp
GF_METADOME_URL=https://metadome-link.genefoundry.org/mcp
GF_ORPHANET_URL=https://orphanet-link.genefoundry.org/mcp
